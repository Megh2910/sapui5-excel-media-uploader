<mvc:View
controllerName="excelproject.controller.MView"
xmlns:mvc="sap.ui.core.mvc"
xmlns="sap.m"
xmlns:unified="sap.ui.unified"
xmlns:core="sap.ui.core">

<Page title="Excel Upload Example">

<VBox class="sapUiSmallMargin">

<Title text="Excel Upload Example" level="H2"/>

<Button
text="Clear Data"
type="Reject"
press="onClearData"
class="sapUiSmallMarginBottom"/>

<!-- Excel Upload -->

<unified:FileUploader
id="excelUpload"
change="onUpload"
placeholder="Upload Excel File"/>

<Table id="empTable" items="{/employees}">
<columns>
<Column><Text text="Employee ID"/></Column>
<Column><Text text="Name"/></Column>
<Column><Text text="Department"/></Column>
</columns>

<items>
<ColumnListItem>
<cells>
<Text text="{Employeeid}"/>
<Text text="{Name}"/>
<Text text="{Department}"/>
</cells>
</ColumnListItem>
</items>
</Table>

<!-- IMAGE SECTION -->

<Title text="Upload Image" level="H3" class="sapUiMediumMarginTop"/>

<unified:FileUploader
id="imageUpload"
change="onImageUpload"
fileType="jpg,png,jpeg"/>

<Image
id="previewImage"
width="500px"
visible="false"/>

<!-- VIDEO SECTION -->

<Title text="Upload Video" level="H3" class="sapUiMediumMarginTop"/>

<unified:FileUploader
id="videoUpload"
change="onVideoUpload"
fileType="mp4,webm"/>

<core:HTML
    id="previewVideo"
    visible="false"
    content='&lt;video id="videoPlayer" width="500" controls="controls"&gt;&lt;/video&gt;'/>
</VBox>

<!-- IMAGE PREVIEW DIALOG -->

<Dialog id="imagePreviewDialog" title="Image Preview">

<VBox alignItems="Center" class="sapUiMediumMargin">

<Image id="dialogImage" width="600px"/>

</VBox>

<beginButton>
<Button text="Upload" type="Emphasized" press="onConfirmImage"/>
</beginButton>

<endButton>
<Button text="Cancel" press="onCancelImage"/>
</endButton>

</Dialog>

<!-- VIDEO PREVIEW DIALOG -->

<Dialog id="videoPreviewDialog" title="Video Preview">

<VBox alignItems="Center" class="sapUiMediumMargin">

<core:HTML
    id="dialogVideo"
    content='&lt;video id="dialogVideoPlayer" width="600" controls="controls"&gt;&lt;/video&gt;'/>

</VBox>

<beginButton>
<Button text="Upload" type="Emphasized" press="onConfirmVideo"/>
</beginButton>

<endButton>
<Button text="Cancel" press="onCancelVideo"/>
</endButton>

</Dialog>

</Page>

</mvc:View>